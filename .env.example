# App
APP_NAME=mind-alcove-ai-backend
ENV=development # development | staging | production (used for health api)
DEBUG=true # Set to false in production to disable Swagger docs and tracebacks

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_name
DB_USER=db_username
DB_PASSWORD=db_password

# Google GenAI
GOOGLE_API_KEY=your_google_api_key_here

# Security
SECRET_KEY=change_this_in_production
S2S_TOKEN_TTL=300 # token ttl for laravel -> fastapi communication

# Langsmith
LANGSMITH_TRACING=false # Set true to send AI calling traces to Langsmith dashboard for monitoring.
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=MindAlcove

# Laravel Service
LARAVEL_BASE_URL=https://mindalcove.yourcloudnetwork.net # Laravel service base url for internal communication

# Logging
LOG_DIR=logs
LOG_ROTATION=00:00  # Rotates log file daily at midnight
LOG_RETENTION="15 days"  # Purges logs older than 15 days to save VPS disk space
LOG_LEVEL=INFO # DEBUG | INFO | WARNING | ERROR
