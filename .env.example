# App
APP_NAME=mind-alcove-ai-backend
ENV=development
DEBUG=true

# Server
HOST=127.0.0.1
PORT=8000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_name
DB_USER=db_username
DB_PASSWORD=db_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Google GenAI
GOOGLE_API_KEY=your_google_api_key_here

# Security
SECRET_KEY=change_this_in_production
