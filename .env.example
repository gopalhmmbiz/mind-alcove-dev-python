# App
APP_NAME=mind-alcove-ai-backend
ENV=development
DEBUG=true

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_name
DB_USER=db_username
DB_PASSWORD=db_password

# Cache
CACHE_TYPE=memory # redis | memory

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Google GenAI
GOOGLE_API_KEY=your_google_api_key_here

# Security
SECRET_KEY=change_this_in_production
S2S_TOKEN_TTL=300

# Langsmith
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=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
LANGSMITH_PROJECT=MindAlcove

# Laravel Service
LARAVEL_BASE_URL=https://mindalcove.yourcloudnetwork.net
ACTIVITY_LIST_ENDPOINT=https://mindalcove.yourcloudnetwork.net/storage/ai-sync/ai-sync.json

# Logging
LOG_DIR=logs
LOG_ROTATION=00:00  # Rotates daily at midnight
LOG_RETENTION="15 days"  # Use quotes for safety
LOG_LEVEL=INFO
